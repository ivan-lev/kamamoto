{
	"compilerOptions": {
		"module": "node16",
		"target": "es2024",
		"outDir": "./dist",
    "rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"moduleResolution": "node16",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"types": ["@types/node"],
	},
	"lib": ["es2024"]
}